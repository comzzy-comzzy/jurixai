# JuriXAI environment variables.
# Copy to `.env` for local dev and fill in real values, OR set these in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.
# Never commit the real `.env`.
#
# Naming rule (Vite/TanStack): variables WITHOUT the VITE_ prefix are server-only
# secrets and never reach the browser. Variables WITH VITE_ are bundled into the
# client and are safe to expose (publishable keys, public URLs).

# ── Circle: server-only secret (controls money) ───────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENV=sandbox

# ── Circle User-Controlled Wallets (email + passkey login) ────────────────
# App ID from User Controlled → Configurator (browser-side, safe to expose)
VITE_CIRCLE_APP_ID=
# Default chain for new wallets (User-Controlled blockchain id)
# Supported options: MATIC-AMOY, ARC-TESTNET, XLAYER-MAINNET, MONAD-MAINNET, MONAD-TESTNET
VITE_CIRCLE_CHAIN=MATIC-AMOY

# ── Circle Modular Wallets (legacy passkey path — optional) ───────────────
VITE_CIRCLE_CLIENT_KEY=
VITE_CIRCLE_CLIENT_URL=

# Wallet Kit key — purpose TBD (confirm in Circle console). Server-only for now.
CIRCLE_KIT_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────
# Browser-side (safe to expose): project URL + anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only: service-role key (full DB access — never expose)
SUPABASE_SERVICE_ROLE_KEY=

# ── App session encryption ────────────────────────────────────────────────
# Used to encrypt the persistent login cookie for profile/dashboard access.
JURIX_SESSION_SECRET=

# ── Real judge model (server-only) ────────────────────────────────────────
# Used by Vex / Kael / Oryn / Zera to generate actual scores and rationales.
# Set JURIX_JUDGE_PROVIDER to `openai` or `minimax`.
# Default base URL targets the matching provider's standard endpoint; override
# it only if you are intentionally using a compatible gateway.
JURIX_JUDGE_PROVIDER=openai
JURIX_JUDGE_API_KEY=
JURIX_JUDGE_MODEL=
JURIX_JUDGE_BASE_URL=https://api.openai.com/v1
