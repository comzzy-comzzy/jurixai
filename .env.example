# JuriXAI environment variables.
# Copy to `.env` for local dev and fill in real values, OR set these in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.
# Never commit the real `.env`.
#
# Naming rule (Vite/TanStack): variables WITHOUT the VITE_ prefix are server-only
# secrets and never reach the browser. Variables WITH VITE_ are bundled into the
# client and are safe to expose (publishable keys, public URLs).

# ── Circle: server-only secret (controls money) ───────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENV=sandbox

# ── Circle Modular Wallets: browser-side (passkey smart accounts) ─────────
# clientKey is a publishable key used by the Web SDK in the browser.
VITE_CIRCLE_CLIENT_KEY=
# clientUrl is the Modular Wallets RPC base from your Circle console
# (e.g. https://modular-sdk.circle.com/v1/rpc/w3s/<appId>)
VITE_CIRCLE_CLIENT_URL=
# Default chain for new wallets
VITE_CIRCLE_CHAIN=ARB-SEPOLIA

# Wallet Kit key — purpose TBD (confirm in Circle console). Server-only for now.
CIRCLE_KIT_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────
# Browser-side (safe to expose): project URL + anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only: service-role key (full DB access — never expose)
SUPABASE_SERVICE_ROLE_KEY=
